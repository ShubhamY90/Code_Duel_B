# ──────────────────────────────────────────
# Firebase Admin SDK
# ──────────────────────────────────────────
# Path to your Firebase service account JSON key
# Download from: Firebase Console → Project Settings → Service Accounts
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# ──────────────────────────────────────────
# Judge0 (self-hosted)
# ──────────────────────────────────────────
# Your Judge0 VM's base URL (no trailing slash)
JUDGE0_URL=http://YOUR_JUDGE0_VM_IP:2358

# Secret to authenticate backend → Judge0 (if you set X-Auth-Token in Judge0 config)
JUDGE0_AUTH_TOKEN=

# ──────────────────────────────────────────
# Server
# ──────────────────────────────────────────
PORT=4000

# CORS — frontend origin(s), comma-separated
CORS_ORIGINS=http://localhost:5173

# ──────────────────────────────────────────
# Matchmaking
# ──────────────────────────────────────────
# Base rating range for initial match (±)
QUEUE_BASE_RANGE=150

# How much to expand range every 30s of waiting (±)
QUEUE_RANGE_EXPANSION=50

# Max range cap
QUEUE_MAX_RANGE=500

# Duel duration in seconds (default 30 min)
DUEL_DURATION_SEC=1800
